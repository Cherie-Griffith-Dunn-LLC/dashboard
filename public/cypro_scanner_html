            </button>
          ))}
        </nav>

        {scanDone&&(
          <div style={{margin:"0 8px 8px",background:"rgba(220,38,38,0.08)",border:"1px solid rgba(220,38,38,0.2)",borderRadius:8,padding:"10px 12px"}}>
            <div style={{color:"var(--red2)",fontSize:10,fontFamily:"DM Sans,sans-serif",fontWeight:700,letterSpacing:"0.02em",marginBottom:4}}>ACTIVE ALERTS</div>
            <div style={{color:"var(--text)",fontSize:11,fontWeight:700}}>{critCount} Critical</div>
            <div style={{color:"var(--text3)",fontSize:9}}>{vulnApps} vulnerable apps</div>
