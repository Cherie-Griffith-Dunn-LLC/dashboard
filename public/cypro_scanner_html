function Dashboard({user,onLogout,autoScan}){
  const [tab,setTab]=useState("overview");
  const [scanning,setScanning]=useState(false);
  const [scanDone,setScanDone]=useState(false);
  const [scanProgress,setScanProgress]=useState(0);
  const [scanType,setScanType]=useState("");
  const [currentStep,setCurrentStep]=useState("");
  const [aiSummary,setAiSummary]=useState("");
  const [aiLoading,setAiLoading]=useState(false);
  const [thirdPartyScanned,setThirdPartyScanned]=useState(false);
  const [webScanned,setWebScanned]=useState(false);
  const [internalScanned,setInternalScanned]=useState(false);
  const [chatOpen,setChatOpen]=useState(false);
  const [chatInput,setChatInput]=useState("");
  const [chatHistory,setChatHistory]=useState([
    {role:"assistant",content:`Welcome back, ${user.name.split(" ")[0]} — I'm CyproAI, your enterprise security analyst. ${scanDone?"Your scan results are ready. Ask me anything about your findings.":"Run a scan to get started, or ask me about cybersecurity best practices."}`}
  ]);
  const [chatLoading,setChatLoading]=useState(false);
  const [reportModal,setReportModal]=useState(false);
  const [reportContent,setReportContent]=useState("");
  const [reportLoading,setReportLoading]=useState(false);
  const [emailInput,setEmailInput]=useState(user.email||"");
  const [emailStatus,setEmailStatus]=useState("idle"); // idle | sending | sent | error
  const [emailInputError,setEmailInputError]=useState(false);
  const chatEnd=useRef(null);
  const scanStartedRef=useRef(false);

  const score=scanDone?58:82;
  const critCount=[...WEB_VULNS,...INTERNAL_VULNS].filter(v=>v.severity==="critical").length;
  const vulnApps=THIRD_PARTY_APPS.filter(a=>a.status==="vulnerable").length;
  const scanDate=new Date().toLocaleDateString("en-US",{year:"numeric",month:"long",day:"numeric"});

  useEffect(()=>{chatEnd.current?.scrollIntoView({behavior:"smooth"});},[chatHistory]);

  // Auto-launch scan if coming from welcome screen
  useEffect(()=>{
    if(autoScan&&!scanStartedRef.current){
      scanStartedRef.current=true;
      setTimeout(()=>runScan("full"),800);
    }
  },[autoScan]);

  const SCAN_STEPS={
    full:[
      "Enumerating network topology and asset inventory...",
      "Connecting to 12 third-party SaaS applications...",
      "Analyzing OAuth scopes and API permissions...",
      "Running OWASP Top 10 web vulnerability assessment...",
      "Testing TLS/SSL configurations and cipher suites...",
      "Mapping internal network and Active Directory...",
      "Cross-referencing 2024–2025 CVE database...",
      "Analyzing identity and access management posture...",
      "Checking HIPAA and SOC 2 compliance gaps...",
      "CyproAI compiling executive risk findings...",
    ],
    thirdparty:[
      "Authenticating to third-party app APIs...",
      "Scanning OAuth token scopes and permissions...",
      "Checking for exposed credentials and secrets...",
      "Analyzing API security configurations...",
      "Detecting shadow IT and unauthorized integrations...",
      "Compiling application risk matrix...",
    ],
    web:[
      "Crawling web application endpoints and sitemaps...",
      "Testing for SQL injection and input validation...",
      "Checking TLS/SSL configuration and certificates...",
      "Scanning for exposed admin interfaces...",
      "Evaluating CORS policies and security headers...",
      "Checking for XSS and CSRF vulnerabilities...",
    ],
    internal:[
      "Mapping internal network topology...",
      "Checking for unpatched CVEs on Windows hosts...",
      "Testing Active Directory security posture...",
      "Scanning for open ports and risky services...",
      "Analyzing privilege escalation paths...",
      "Reviewing stale accounts and access anomalies...",
    ],
  };

  const runScan=async(type)=>{
    setScanType(type);
    setScanning(true);
    setScanProgress(0);
    setAiSummary("");
    const steps=SCAN_STEPS[type]||SCAN_STEPS.full;

    // Animate through steps
    for(let i=0;i<steps.length;i++){
      setCurrentStep(steps[i]);
      const targetPct=((i+1)/steps.length)*100;
      // Smooth progress to target
      await new Promise(res=>{
        const start=((i)/steps.length)*100;
        const dur=700+Math.random()*500;
        const startTime=Date.now();
        const tick=()=>{
          const elapsed=Date.now()-startTime;
          const pct=start+(targetPct-start)*Math.min(elapsed/dur,1);
          setScanProgress(pct);
          if(elapsed<dur)requestAnimationFrame(tick);
          else res();
        };
        requestAnimationFrame(tick);
      });
      await new Promise(r=>setTimeout(r,200+Math.random()*300));
    }

    setScanProgress(100);
    setScanning(false);
    setScanDone(true);
    setCurrentStep("");

    if(type==="full"||type==="thirdparty")setThirdPartyScanned(true);
    if(type==="full"||type==="web")setWebScanned(true);
    if(type==="full"||type==="internal")setInternalScanned(true);

    if(type==="full")setTab("overview");
    else if(type==="thirdparty")setTab("thirdparty");
    else if(type==="web")setTab("webvuln");
    else if(type==="internal")setTab("internal");

    // Generate AI executive summary
    setAiLoading(true);
    try{
      const txt=await callAI(
        "You are CyproAI, the AI security analyst for CyproSecure 360° by Cyproteck Technologies — Healthcare's Digital Bodyguard™. Be executive-level, precise, urgent, and tie every finding to HIPAA compliance and business risk. Never use bullet points in the first paragraph.",
        `Generate a 3-paragraph executive summary for ${user.company}. Coverage: (1) Overall security posture — score 58/100, at-risk rating, business impact to operations and patient data. (2) Most critical findings: ${critCount} critical vulnerabilities across web and internal systems, ${vulnApps} vulnerable third-party apps including AWS (root MFA missing, public S3 buckets), Workday (SSO bypass, PII exposed), Salesforce (over-permissioned OAuth), plus CVE-2024-21413 on domain controller and pass-the-hash attack path across 14 workstations. (3) Immediate recommended remediation priorities and why Cyproteck's managed security team should lead the response. Keep under 220 words. Do not use bullet points.`
      );
      setAiSummary(txt);
    }catch(e){
      setAiSummary(`Scan complete for ${user.company}. CyproAI identified ${critCount} critical vulnerabilities requiring immediate attention. AWS root MFA and Workday SSO bypass represent the highest business risk. Contact Cyproteck for emergency remediation support.`);
    }
    setAiLoading(false);
  };

  const genReport=async()=>{
    setReportModal(true);
    setReportLoading(true);
    setReportContent("");
    setEmailStatus("idle");
    try{
      const txt=await callAI(
        "You are CyproAI generating a formal, branded executive security briefing for Cyproteck Technologies — Healthcare's Digital Bodyguard™. Use professional report formatting with clear section headers in ALL CAPS followed by a colon. Be authoritative, precise, and tie everything to HIPAA and SOC 2.",
        `Generate a complete executive security briefing for ${user.company} (contact: ${user.name}, ${user.email}). Include these exact sections:

EXECUTIVE SUMMARY:
SECURITY POSTURE SCORE: 58/100 — At Risk
SCAN DATE: ${scanDate}

CRITICAL FINDINGS OVERVIEW:
List all ${critCount} critical vulnerabilities with host/system, CVE where applicable, and business impact.

THIRD-PARTY APPLICATION RISK:
Cover all 12 apps scanned. Highlight critical: AWS (root MFA missing, 2 public S3 buckets, IAM wildcards), Workday HCM (SSO bypass, PII via API, password policy failure). High risk: Salesforce, QuickBooks. Warning: DocuSign, GitHub, Zoom.

WEB APPLICATION VULNERABILITIES:
SQL Injection (CVSS 9.8), Exposed Admin Panel (CVSS 9.1), XSS, outdated TLS, CORS misconfiguration.

INTERNAL NETWORK FINDINGS:
CVE-2024-21413 on WINSERVER-DC01 (unpatched since Feb 2024), Pass-the-Hash across 14 workstations, Open RDP on 192.168.10.44, SMBv1 active on FILESERVER-02.

HIPAA / SOC 2 COMPLIANCE IMPACT:
Explain specific risks to PHI and audit exposure.

REMEDIATION ROADMAP:
30-DAY PRIORITIES (critical): Patch DC01, enforce MFA on AWS root, close SSO bypass
60-DAY ACTIONS (high): IP restrictions, TLS upgrade, RDP lockdown
90-DAY HARDENING (medium/long-term): Full IAM review, legacy protocol removal

NEXT STEPS — HOW CYPROTECK CAN HELP:
Write 3–4 sentences explaining what the client should do immediately, why delay is dangerous, and a direct, warm call to action to contact Cherie Griffith-Dunn personally to schedule a remediation consultation. Mention CyproSecure 360° Professional or Enterprise as the recommended managed security solution. End with: "Contact us today — we are ready to begin." Then on new lines: Phone: (959) 888-0569 | Email: Cherie@cyproteck.com | Website: www.cyproteck.com | Operations: ops@cyproteck.com

Keep under 750 words. Use clear section headers in ALL CAPS. Be professional, precise, and empathetic — the goal is to help this organization, not alarm them.`,
        1800
      );
      setReportContent(txt);
    }catch(e){
      setReportContent(`CYPROSECURE 360° EXECUTIVE BRIEFING\n${user.company} | ${scanDate}\n\nSecurity Score: 58/100 — At Risk\n\nCritical findings have been identified across your environment. Our team is ready to walk you through every finding and build your remediation roadmap.\n\nContact us today — we are here to help.\n\nCherie Griffith-Dunn, CEO\n(959) 888-0569\nCherie@cyproteck.com\nwww.cyproteck.com`);
    }
    setReportLoading(false);
  };

  const handleSendEmail=()=>{
    if(!emailInput.includes("@")){
      setEmailInputError(true);
      return;
    }
    setEmailInputError(false);
    setEmailStatus("sending");
    setTimeout(()=>{
      const ok=sendReportEmail(emailInput,reportContent,user.company,user.name,scanDate);
      setEmailStatus(ok?"sent":"error");
    },900);
  };

  const sendChat=async()=>{
    if(!chatInput.trim()||chatLoading)return;
    const msg={role:"user",content:chatInput};
    const hist=[...chatHistory,msg];
    setChatHistory(hist);
    setChatInput("");
    setChatLoading(true);
    try{
      const res=await fetch(API,{
        method:"POST",
        headers:{"Content-Type":"application/json"},
        body:JSON.stringify({
          model:MODEL,
          max_tokens:800,
          system:`You are CyproAI, the AI security analyst for CyproSecure 360° by Cyproteck Technologies — Healthcare's Digital Bodyguard™. You serve ${user.name} at ${user.company}. Current security score is ${score}/100. ${scanDone?"A full scan has been completed revealing "+critCount+" critical vulnerabilities.":"No scan has been run yet."} Be concise, authoritative, and always relate findings to HIPAA risk and business impact. When relevant, recommend Cyproteck's managed security services.`,
          messages:hist.map(m=>({role:m.role,content:m.content}))
        })
      });
      const d=await res.json();
      setChatHistory(h=>[...h,{role:"assistant",content:d.content?.[0]?.text||"Connection issue — please retry."}]);
    }catch{
      setChatHistory(h=>[...h,{role:"assistant",content:"Connection issue — please retry."}]);
    }
    setChatLoading(false);
  };

  const NAV=[
    {id:"overview",icon:"⬡",label:"Overview"},
    {id:"thirdparty",icon:"🔗",label:"3rd Party Apps"},
    {id:"webvuln",icon:"🌐",label:"Web Scanner"},
    {id:"internal",icon:"🖥️",label:"Internal Scan"},
    {id:"reports",icon:"📊",label:"Reports"},
    {id:"upgrade",icon:"🚀",label:"Upgrade"},
  ];

  return(
