/* ═══════════════════════════════════════════
   ROOT APP — manages auth + welcome flow
═══════════════════════════════════════════ */
function App(){
  const [user,setUser]=useState(null);
  const [appState,setAppState]=useState("auth"); // auth | welcome | dashboard
  const [autoScan,setAutoScan]=useState(false);

  const handleLogin=(u)=>{
    setUser(u);
    // New accounts (signup) go to welcome/scan screen
    // Returning accounts (login/SSO) go straight to dashboard
    if(u.isNew){
      setAppState("welcome");
    }else{
      setAppState("dashboard");
    }
  };

  const handleStartScan=()=>{
    setAutoScan(true);
    setAppState("dashboard");
  };

  const handleSkip=()=>{
    setAutoScan(false);
    setAppState("dashboard");
  };

  const handleLogout=()=>{
    setUser(null);
    setAppState("auth");
    setAutoScan(false);
  };

  if(appState==="auth") return <LoginPage onLogin={handleLogin}/>;
  if(appState==="welcome") return <WelcomeScan user={user} onStartScan={handleStartScan} onSkip={handleSkip}/>;
  return <Dashboard user={user} onLogout={handleLogout} autoScan={autoScan}/>;
}

ReactDOM.createRoot(document.getElementById("root")).render(<App/>);
