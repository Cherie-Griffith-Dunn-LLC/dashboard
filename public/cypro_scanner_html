            <button onClick={handleSubmit} disabled={loading}
              style={{padding:"12px",background:"linear-gradient(135deg,#0a7066,#0d9488)",border:"none",borderRadius:8,color:"#fff",fontSize:12,fontWeight:700,boxShadow:"0 0 18px rgba(13,148,136,0.3)",animation:"glow-pulse 3s infinite",opacity:loading?0.7:1,marginTop:2}}>
              {loading
                ?<span style={{display:"flex",alignItems:"center",justifyContent:"center",gap:7}}>
                    <span style={{width:13,height:13,border:"2px solid rgba(255,255,255,0.3)",borderTopColor:"#fff",borderRadius:"50%",animation:"spin 0.8s linear infinite",display:"inline-block"}}/>
                    {mode==="signup"?"Creating your account...":"Signing in..."}
                  </span>
                :mode==="login"?"Sign In to CyproSecure 360°":"Create Account & Start Scanning"}
            </button>
          </form>

          <p style={{textAlign:"center",marginTop:16,fontSize:10,color:"var(--text3)",fontFamily:"DM Sans,sans-serif"}}>
            SOC 2 TYPE II CERTIFIED — HIPAA COMPLIANT — 256-BIT ENCRYPTION
          </p>
        </div>

        <p style={{textAlign:"center",marginTop:14,fontSize:10,color:"var(--text3)"}}>
          New accounts receive a complimentary full security scan — <span style={{color:"var(--teal2)"}}>No credit card required</span>
        </p>
      </div>
    </div>
  );
}

