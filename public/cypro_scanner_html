              style={{display:"flex",alignItems:"center",gap:9,padding:"8px 10px",background:tab===n.id?"rgba(13,148,136,0.1)":"transparent",border:"1px solid "+(tab===n.id?"rgba(13,148,136,0.22)":"transparent"),borderRadius:6,color:tab===n.id?"var(--teal2)":"var(--text2)",fontSize:11,fontWeight:tab===n.id?600:400,textAlign:"left",transition:"all 0.15s"}}>
              <span style={{fontSize:13,opacity:tab===n.id?1:0.65}}>{n.icon}</span>
